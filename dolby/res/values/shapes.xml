<resources>

    <!-- Material 3 Expressive Shape Styles -->
    <!-- Extra Large Shapes - For prominent surfaces -->
    <style name="ShapeAppearance.Dolby.CornerExtraLarge" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">32dp</item>
    </style>
    
    <!-- Large Shapes - For cards and containers -->
    <style name="ShapeAppearance.Dolby.CornerLarge" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    
    <!-- Medium Shapes - For buttons and chips -->
    <style name="ShapeAppearance.Dolby.CornerMedium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <!-- Small Shapes - For small components -->
    <style name="ShapeAppearance.Dolby.CornerSmall" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <!-- Extra Small Shapes - For minimal rounding -->
    <style name="ShapeAppearance.Dolby.CornerExtraSmall" parent="ShapeAppearance.Material3.Corner.ExtraSmall">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>
    
    <!-- Full Rounded - For pills and toggles -->
    <style name="ShapeAppearance.Dolby.CornerFull" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    
    <!-- Preference-specific shapes -->
    <style name="ShapeAppearance.Dolby.PreferenceCard" parent="ShapeAppearance.Dolby.CornerMedium">
        <item name="cornerSize">20dp</item>
    </style>
    
    <style name="ShapeAppearance.Dolby.PreferenceCategory" parent="ShapeAppearance.Dolby.CornerSmall">
        <item name="cornerSize">12dp</item>
    </style>
    
    <!-- Button shapes with enhanced expressiveness -->
    <style name="ShapeAppearance.Dolby.Button" parent="ShapeAppearance.Dolby.CornerFull">
        <!-- Fully rounded buttons for modern look -->
    </style>
    
    <style name="ShapeAppearance.Dolby.ButtonSmall" parent="ShapeAppearance.Dolby.CornerMedium">
        <item name="cornerSize">20dp</item>
    </style>
    
    <!-- Floating Action Button -->
    <style name="ShapeAppearance.Dolby.FloatingActionButton" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>
    
    <!-- Dialog and Modal shapes -->
    <style name="ShapeAppearance.Dolby.Dialog" parent="ShapeAppearance.Dolby.CornerLarge">
        <item name="cornerSize">28dp</item>
    </style>
    
    <!-- Bottom Sheet -->
    <style name="ShapeAppearance.Dolby.BottomSheet" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
    
    <!-- Navigation Rail -->
    <style name="ShapeAppearance.Dolby.NavigationRail" parent="ShapeAppearance.Dolby.CornerLarge">
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomRight">24dp</item>
    </style>
    
    <!-- Chip shapes -->
    <style name="ShapeAppearance.Dolby.Chip" parent="ShapeAppearance.Dolby.CornerSmall">
        <item name="cornerSize">12dp</item>
    </style>
    
    <!-- Card shapes with enhanced Material 3 Expressive styling -->
    <style name="ShapeAppearance.Dolby.Card" parent="ShapeAppearance.Dolby.CornerMedium">
        <item name="cornerSize">16dp</item>
    </style>
    
    <style name="ShapeAppearance.Dolby.CardElevated" parent="ShapeAppearance.Dolby.Card">
        <item name="cornerSize">20dp</item>
    </style>

</resources>