    <!-- Preference-specific typography -->
    <style name="TextAppearance.Dolby.PreferenceTitle" parent="TextAppearance.Dolby.TitleMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
    
    <style name="TextAppearance.Dolby.PreferenceSummary" parent="TextAppearance.Dolby.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
    
    <style name="TextAppearance.Dolby.PreferenceCategoryTitle" parent="TextAppearance.Dolby.LabelLarge">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="fontWeight">600</item>
    </style>
    
